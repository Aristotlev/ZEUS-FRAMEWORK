# ============================================================================
# Zeus Framework — Production env (Hetzner)
# ============================================================================
# Copy to .env.prod and fill in. Never commit .env.prod.
# Loaded by docker compose via --env-file=deploy/.env.prod
# ============================================================================

# ── Public hostname (point an A record at the Hetzner IP first) ─────────────
ZEUS_DOMAIN=zeus.example.com
# Let's Encrypt account email
ACME_EMAIL=you@example.com

# ── Status dashboard / remote trigger auth ──────────────────────────────────
# Long random string. `openssl rand -hex 32` to generate.
# Used as Bearer token for /trigger and /webhook endpoints.
ZEUS_TRIGGER_TOKEN=replace_me_with_openssl_rand_hex_32

# ── Postgres (colocated, kept on private docker network) ────────────────────
POSTGRES_DB=hermes_vectors
POSTGRES_USER=hermes
POSTGRES_PASSWORD=replace_me_strong_random_password

# ── Agent runtime ───────────────────────────────────────────────────────────
HERMES_UID=1000
ZEUS_MODEL=deepseek/deepseek-v4-pro

# ── LLM (required) ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=

# ── Content pipeline external services ──────────────────────────────────────
FAL_KEY=
FISH_AUDIO_API_KEY=
ZEUS_FISH_VOICE_DEFAULT=

NOTION_API_KEY=
# Direct DB id of the archive database (skips parent-page discovery).
# Set this OR ZEUS_NOTION_HUB_PAGE_ID.
NOTION_ARCHIVE_DB_ID=
# Optional: id of the per-publish "Content Pipeline" DB. If unset, Zeus
# auto-discovers a child DB titled "Content Pipeline" under the hub page.
# When neither is set, the per-publish DB feature is silently skipped — the
# archive DB still gets a row.
NOTION_PIPELINE_DB_ID=
# Notion content-hub parent page id (needed for auto-discovery of either DB
# above when their ids aren't pinned). 32-char hex from the page URL.
ZEUS_NOTION_HUB_PAGE_ID=

# ── Publer (publishing) ─────────────────────────────────────────────────────
PUBLER_API_KEY=
PUBLER_WORKSPACE_ID=
PUBLER_TWITTER_ID=
PUBLER_INSTAGRAM_ID=
PUBLER_LINKEDIN_ID=
PUBLER_TIKTOK_ID=
PUBLER_YOUTUBE_ID=
PUBLER_FACEBOOK_ID=
PUBLER_REDDIT_ID=

# ── Email backend (pick ONE — leave the others empty) ───────────────────────
# Resend (recommended) — just the API key, from-address auto-derived.
RESEND_API_KEY=
# AgentMail — BOTH the API key AND the inbox address are required. Get the
# inbox by hitting `GET https://api.agentmail.to/v0/inboxes` with your key.
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX=
# Gmail SMTP fallback — needs an App Password (NOT your regular gmail password).
# Generate at https://myaccount.google.com/apppasswords with 2FA on.
HERMES_GMAIL_USER=
HERMES_GMAIL_APP_PASSWORD=

ZEUS_NOTIFY_EMAIL=you@example.com
ZEUS_NOTIFY_FROM_NAME=Zeus
ZEUS_NOTIFY_FROM_EMAIL=

# ── Backups to Backblaze B2 (rclone-style) ──────────────────────────────────
# Leave these empty to keep backups local-only at /var/backups/zeus.
# To enable B2 offsite: create a B2 bucket + Application Key, fill in below.
B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=zeus-backups

# ── Hetzner Cloud (optional — lets Zeus manage his own infra) ───────────────
# Generate at console.hetzner.cloud → project → Security → API Tokens.
# Read & Write scope. Leave empty if Zeus doesn't need cloud-control tools.
HCLOUD_TOKEN=
