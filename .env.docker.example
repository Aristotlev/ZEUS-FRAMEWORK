# ============================================================================
# ⚡ Zeus Framework — Docker Environment
# ============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.docker.example .env
#
# Required: OPENROUTER_API_KEY
# Everything else has working defaults for the Docker stack.
# ============================================================================

# ── Required ─────────────────────────────────────────────────────────────────
# Get your free key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY_HERE

# ── Model selection (optional) ────────────────────────────────────────────────
# Any model available on https://openrouter.ai/models
# Examples: anthropic/claude-sonnet-4  |  openai/gpt-4o  |  deepseek/deepseek-r1
ZEUS_MODEL=anthropic/claude-sonnet-4

# ── PostgreSQL / Mnemosyne (auto-configured — change only if needed) ──────────
POSTGRES_DB=hermes_vectors
POSTGRES_USER=hermes
POSTGRES_PASSWORD=hermes_local

# ── Optional integrations ────────────────────────────────────────────────────
# DISCORD_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# ── EVENT_CLIP pipeline (optional) ───────────────────────────────────────────
# Comma-separated YouTube channel URLs the watcher polls. Default list (gov/
# official only) lives in lib/event_clip.py:DEFAULT_CHANNELS. Override to add
# corporate IR channels or trim the list. NEVER add CNBC/Bloomberg/WSJ/Reuters
# — their clips will get the account struck within weeks.
# EVENT_CLIP_CHANNELS=https://www.youtube.com/@federalreserve,https://www.youtube.com/@cspan
# How many hours back to scan each channel on every cron tick (default 24).
# EVENT_CLIP_LOOKBACK_HOURS=24
# Path to a cookies.txt file exported from a logged-in YouTube browser session.
# REQUIRED for the cron path on datacenter VMs — YouTube hard-blocks Hetzner/
# AWS/GCP IP ranges with "Sign in to confirm you're not a bot." Export via
# "Get cookies.txt LOCALLY" browser extension from a logged-in YouTube tab,
# scp to the VM, then set this var. Cookies last ~weeks; re-export when stale.
# EVENT_CLIP_YOUTUBE_COOKIES_PATH=/opt/zeus/deploy/youtube_cookies.txt
# Override proxy specifically for yt-dlp. Datacenter proxies (Webshare basic)
# DO NOT bypass YouTube's bot wall — only residential tiers do. Falls back
# silently to ZEUS_PICKER_PROXY_URL only when this var is set, so the picker's
# datacenter proxy doesn't accidentally route YouTube traffic.
# EVENT_CLIP_PROXY_URL=http://user:pass@residential.example.com:8080
